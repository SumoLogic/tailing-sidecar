{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": ["dependencies"],
  // Disable managers that Dependabot already covers
  "enabledManagers": [
    "helm-values"
  ],
  "helm-values": {
    "fileMatch": [
      "helm/tailing-sidecar-operator/values\\.yaml"
    ]
  }
}
